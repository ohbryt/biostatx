# ============================================
# BioStatX Environment Variables
# Copy this file to .env.local and fill in values
# ============================================

# Supabase (https://supabase.com → New Project → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# PortOne V2 (https://admin.portone.io → 결제연동 → 연동정보)
NEXT_PUBLIC_PORTONE_STORE_ID=store-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
NEXT_PUBLIC_PORTONE_CHANNEL_KEY=channel-key-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PORTONE_API_SECRET=your-portone-v2-api-secret

# OpenAI (https://platform.openai.com/api-keys) — for AI Figure Generator
OPENAI_API_KEY=sk-your-openai-api-key-here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
